{% extends 'base.html.twig' %}

{% block title %}Inscription — SymfoConnect{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1 class="auth-card__title">Créer un compte</h1>
            <p class="auth-card__sub">Rejoins la communauté SymfoConnect</p>
        </div>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {attr: {class: 'auth-form', novalidate: 'novalidate'}}) }}

            <div class="form-group {{ form_errors(registrationForm.email) is not empty ? 'form-group--error' }}">
                {{ form_label(registrationForm.email, 'Adresse e-mail') }}
                {{ form_widget(registrationForm.email, {attr: {placeholder: 'toi@exemple.com'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="form-group {{ form_errors(registrationForm.plainPassword) is not empty ? 'form-group--error' }}">
                {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
                {{ form_widget(registrationForm.plainPassword, {attr: {placeholder: '6 caractères minimum'}}) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>

            <div class="form-group form-group--checkbox {{ form_errors(registrationForm.agreeTerms) is not empty ? 'form-group--error' }}">
                {{ form_widget(registrationForm.agreeTerms) }}
                {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions d'utilisation") }}
                {{ form_errors(registrationForm.agreeTerms) }}
            </div>

            <button type="submit" class="btn-submit btn-submit--full">S'inscrire</button>

        {{ form_end(registrationForm) }}

        <p class="auth-card__footer">
            Déjà un compte ? <a href="/login">Se connecter</a>
        </p>
    </div>
</div>
{% endblock %}
