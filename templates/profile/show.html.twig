{% extends 'base.html.twig' %}

{% block title %}{{ profileUser.username }} — SymfoConnect{% endblock %}

{% block body %}
<div class="profile">

    <div class="profile-card">
        <div class="profile-avatar">
            {% if profileUser.avatar %}
                <img src="{{ profileUser.avatar }}" alt="Avatar de {{ profileUser.username }}">
            {% else %}
                <div class="profile-avatar__placeholder">{{ profileUser.username|first|upper }}</div>
            {% endif %}
        </div>
        <div class="profile-info">
            <div class="profile-info__top">
                <h1 class="profile-username">{{ profileUser.username }}</h1>

                {% if app.user and app.user.username != profileUser.username %}
                    <div class="profile-actions">
                        {% if isFollowing %}
                            <form method="post" action="{{ path('app_unfollow', {username: profileUser.username}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('unfollow_' ~ profileUser.id) }}">
                                <button type="submit" class="btn-follow btn-follow--active">Ne plus suivre</button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_follow', {username: profileUser.username}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('follow_' ~ profileUser.id) }}">
                                <button type="submit" class="btn-follow">Suivre</button>
                            </form>
                        {% endif %}
                        <a href="{{ path('app_conversation', {username: profileUser.username}) }}" class="btn-message">Message</a>
                    </div>
                {% endif %}
            </div>

            {% if profileUser.bio %}
                <p class="profile-bio">{{ profileUser.bio }}</p>
            {% else %}
                <p class="profile-bio profile-bio--empty">Aucune bio renseignée.</p>
            {% endif %}

            <div class="profile-stats">
                <span class="profile-stat">
                    <strong>{{ posts|length }}</strong> post{{ posts|length > 1 ? 's' : '' }}
                </span>
                <span class="profile-stat">
                    <strong>{{ followersCount }}</strong> follower{{ followersCount > 1 ? 's' : '' }}
                </span>
            </div>
        </div>
    </div>

    <h2 class="profile-section-title">Posts de {{ profileUser.username }}</h2>

    {% if posts is empty %}
        <p class="hub-empty">Aucun post pour le moment.</p>
    {% else %}
        <div class="posts-grid">
            {% for post in posts %}
                {{ include('_post_card.html.twig', {post: post, showAuthor: false}) }}
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
