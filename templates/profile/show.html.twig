{% extends 'base.html.twig' %}

{% block title %}{{ profileUser.username }} — SymfoConnect{% endblock %}

{% block body %}
<div class="profile">

    <div class="profile-card">
        <div class="profile-avatar">
            {% if profileUser.avatar %}
                <img src="{{ profileUser.avatar }}" alt="Avatar de {{ profileUser.username }}">
            {% else %}
                <div class="profile-avatar__placeholder">{{ profileUser.username|first|upper }}</div>
            {% endif %}
        </div>
        <div class="profile-info">
            <h1 class="profile-username">{{ profileUser.username }}</h1>
            {% if profileUser.bio %}
                <p class="profile-bio">{{ profileUser.bio }}</p>
            {% else %}
                <p class="profile-bio profile-bio--empty">Aucune bio renseignée.</p>
            {% endif %}
            <span class="profile-posts-count">
                {{ posts|length }} post{{ posts|length > 1 ? 's' : '' }}
            </span>
        </div>
    </div>

    <h2 class="profile-section-title">Posts de {{ profileUser.username }}</h2>

    {% if posts is empty %}
        <p class="hub-empty">Aucun post pour le moment.</p>
    {% else %}
        <div class="posts-grid">
            {% for post in posts %}
                <article class="post-card">
                    {% if post.image %}
                        <div class="post-card__image">
                            <img src="{{ post.image }}" alt="Post de {{ profileUser.username }}">
                        </div>
                    {% endif %}
                    <div class="post-card__body">
                        <div class="post-card__meta">
                            {% if post.location %}
                                <span class="post-card__location">{{ post.location }}</span>
                            {% endif %}
                        </div>
                        {% if post.description %}
                            <p class="post-card__desc">{{ post.description }}</p>
                        {% endif %}
                        <time class="post-card__date" datetime="{{ post.createdAt|date('Y-m-d') }}">
                            {{ post.createdAt|date('d/m/Y à H:i') }}
                        </time>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
