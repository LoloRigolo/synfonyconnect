{% extends 'base.html.twig' %}

{% block title %}Hub — SymfoConnect{% endblock %}

{% block body %}
<div class="hub">
    <div class="hub-header">
        <h1 class="hub-title">Hub</h1>
        <div class="hub-sort">
            <span class="sort-label">Trier par :</span>
            <a href="{{ path('app_home', {sort: 'DESC'}) }}"
               class="sort-btn {{ sort == 'DESC' ? 'sort-btn--active' : '' }}">
                Plus récent
            </a>
            <a href="{{ path('app_home', {sort: 'ASC'}) }}"
               class="sort-btn {{ sort == 'ASC' ? 'sort-btn--active' : '' }}">
                Plus vieux
            </a>
        </div>
    </div>

    {% if posts is empty %}
        <p class="hub-empty">Aucun post pour le moment.</p>
    {% else %}
        <div class="posts-grid">
            {% for post in posts %}
                {{ include('_post_card.html.twig', {post: post, showAuthor: true}) }}
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
