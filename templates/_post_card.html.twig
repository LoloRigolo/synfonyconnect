<article class="post-card">
    {% if post.image %}
        <div class="post-card__image">
            <img src="{{ post.image }}" alt="Post de {{ post.user.username }}">
        </div>
    {% endif %}
    <div class="post-card__body">
        <div class="post-card__meta">
            {% if showAuthor is not defined or showAuthor %}
                <a href="{{ path('app_profile', {username: post.user.username}) }}" class="post-card__author">{{ post.user.username }}</a>
            {% endif %}
            {% if post.location %}
                <span class="post-card__location">{{ post.location }}</span>
            {% endif %}
        </div>
        {% if post.description %}
            <p class="post-card__desc">{{ post.description }}</p>
        {% endif %}
        <div class="post-card__footer">
            <time class="post-card__date" datetime="{{ post.createdAt|date('Y-m-d') }}">
                {{ post.createdAt|date('d/m/Y à H:i') }}
            </time>
            <div class="post-card__actions">
            {% if is_granted('POST_DELETE', post) %}
                <form method="post" action="{{ path('app_post_delete', {id: post.id}) }}"
                      onsubmit="return confirm('Supprimer ce post ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                    <button type="submit" class="btn-delete" title="Supprimer">✕</button>
                </form>
            {% endif %}
            <div class="post-card__like">
                {% if app.user %}
                    {% set liked = post.isLikedBy(app.user) %}
                    <form method="post" action="{{ path(liked ? 'app_post_unlike' : 'app_post_like', {id: post.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('like_' ~ post.id) }}">
                        <button type="submit" class="btn-like {{ liked ? 'btn-like--active' : '' }}" title="{{ liked ? 'Retirer le like' : 'Liker' }}">
                            ♥ {{ post.likesCount }}
                        </button>
                    </form>
                {% else %}
                    <span class="like-count">♥ {{ post.likesCount }}</span>
                {% endif %}
            </div>
            </div>
        </div>
    </div>
</article>
